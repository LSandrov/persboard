# Copy this file to `.env` (NOT committed) to configure local `docker-compose` runs.

# Backend (Go API)
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=persboard
DB_USER=persboard
DB_PASSWORD=persboard
DB_SSLMODE=disable

# Frontend (Vite build-time)
VITE_API_BASE_URL=http://localhost:8080

# EazyBI integration (optional; if BASE_URL/ACCOUNT_ID/EXPORT_PREFIX are set, SSRF allowlist is required)
EAZYBI_BASE_URL=https://jira.example.com
EAZYBI_EXPORT_PREFIX=/plugins/servlet/eazybi
EAZYBI_ACCOUNT_ID=1
EAZYBI_AUTH_MODE=basic

# Basic auth credentials for self-hosted EazyBI
EAZYBI_USERNAME=change-me
EAZYBI_PASSWORD=change-me

# SSRF protection allowlist (comma-separated). Must include the EAZYBI host.
EAZYBI_ALLOWED_HOSTS=jira.example.com

# Embed auth token (used when EAZYBI_AUTH_MODE=embed)
# EAZYBI_EMBED_TOKEN=change-me

# Metric definitions for calendar export (optional; if empty, backend falls back to mock metrics).
# Must be a single-line JSON array.
CALENDAR_METRICS_JSON=[{"key":"tickets","title":"Tickets","defaultWeight":1,"metricType":"positive","targetOperator":"gt","targetValue":{"number":100},"eazybiReportId":123,"eazybiFormat":"csv","timeMemberFormat":"[Time].[%s]"},{"key":"defectsPerSprint","title":"Defects / sprint","defaultWeight":1,"metricType":"negative","targetOperator":"lt","targetValue":{"number":5},"eazybiReportId":456,"eazybiFormat":"csv","timeMemberFormat":"[Time].[%s]"}]

